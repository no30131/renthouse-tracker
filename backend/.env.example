# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://renthouse:renthouse@localhost:5432/renthouse

# ── Auth ──────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# 用 `uv run python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"` 產生
ADMIN_PASSWORD_HASH=$2b$12$...
JWT_SECRET_KEY=change_me_to_a_random_secret_string

# ── External APIs ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
MAPBOX_TOKEN=your_mapbox_token_here

# ── Webhook ───────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change_me_to_a_random_webhook_secret

# ── CORS ──────────────────────────────────────────────────────────────────
# 前端開發伺服器來源，多個來源以逗號分隔
CORS_ORIGINS=http://localhost:3000

# ── 爬蟲 ──────────────────────────────────────────────────────────────────
# 設為 true 時啟用排程爬蟲（預設關閉）；搜尋條件設定在 backend/app/crawler_config.py
CRAWLER_ENABLED=false
